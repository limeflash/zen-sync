{
  "manifest_version": 2,
  "name": "Zen Sync",
  "version": "0.1.0",
  "description": "End-to-end encrypted sync of Zen Browser workspaces across devices.",
  "browser_specific_settings": {
    "gecko": {
      "id": "zensync@limeflash.dev",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "nativeMessaging",
    "storage",
    "alarms",
    "https://*/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "Zen Sync",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png",
      "256": "icons/icon-256.png"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png"
  }
}
